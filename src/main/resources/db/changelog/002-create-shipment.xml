<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002-create-shipment" author="nikola.ljubicic">
        <createTable tableName="shipment">
            <column name="id" type="BIGINT">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="tracking_number" type="VARCHAR(40)">
                <constraints nullable="false" unique="true" uniqueConstraintName="uq_shipment_tracking_number"/>
            </column>
            <column name="description" type="VARCHAR(500)"/>
            <column name="current_status" type="VARCHAR(30)" defaultValue="CREATED">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="TIMESTAMP" defaultValueComputed="now()">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            baseTableName="shipment"
            baseColumnNames="user_id"
            constraintName="fk_shipment_user"
            referencedTableName="app_user"
            referencedColumnNames="id"/>
    </changeSet>

</databaseChangeLog>
